@{
}

@model Chapeau_Project.ViewModels.TableOverviewViewModel

@{
    ViewData["Title"] = "Restaurant Overview";
}

<h4>Restaurant Overview</h4>

@if (Model.LoggedInEmployee != null)
{
    <p>Welcome, @Model.LoggedInEmployee.FirstName (@Model.LoggedInEmployee.Role)</p>
}

<div>
    <a asp-controller="Account" asp-action="Logoff">Log Off</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Table Number</th>
            <th>Capacity</th>
            <th>Status</th>
            <th>Assigned Employee</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var table in Model.Tables)
        {
            <tr>
                <td>@table.TableNumber</td>
                <td>@table.Capacity</td>
                <td>@table.Status</td>
                <td>@table.EmployeeId</td>
            </tr>
        }
    </tbody>
</table>

<p><strong>Note:</strong> Overview can be refreshed manually (F5) to see current seating status.</p>